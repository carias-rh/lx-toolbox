# LX Toolbox Environment Variables Template
# Copy this file to .env and fill in your credentials

# ROL Environment Credentials
RH_USERNAME=

# GitHub Credentials (for Factory)
GITHUB_USERNAME=

# China Environment Credentials
CHINA_USERNAME=

# ServiceNow API
SNOW_INSTANCE_URL=https://redhat.service-now.com
SNOW_API_USER=
SNOW_API_PASSWORD=

# LMS API (for user name lookups)
LMS_USERNAME=
LMS_CLIENT_ID=
LMS_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Team Configuration
# ---------------------------------------------------------------------------
# Each team reads {SECTION}_{KEY} env vars via ConfigManager.
# ASSIGNMENT_GROUP_ID  – ServiceNow assignment_group sys_id (comma-separated
#                        for teams with multiple groups, e.g. GLS Engagement NA)
# FRONTEND_OPENSHIFT_ROUTE – URL of the shift-scheduler frontend for the team
# ACKNOWLEDGMENT_TEMPLATE  – (optional) acknowledgment message sent to customers
#                            Supports placeholders: {customer_name}, {assignee_name}, {team_name}

# T1 Team
T1_FRONTEND_OPENSHIFT_ROUTE=
T1_ASSIGNMENT_GROUP_ID=

# T2 Team
T2_FRONTEND_OPENSHIFT_ROUTE=
T2_ASSIGNMENT_GROUP_ID=

# GLS RHLS Engagement
GLS_RHLS_ENGAGEMENT_APAC_ASSIGNMENT_GROUP_ID=
GLS_RHLS_ENGAGEMENT_EMEA_ASSIGNMENT_GROUP_ID=
GLS_RHLS_ENGAGEMENT_NA_ASSIGNMENT_GROUP_ID=

# Remote Exam - Readiness Support
REMOTE_EXAM_READINESS_SUPPORT_ASSIGNMENT_GROUP_ID=
REMOTE_EXAM_READINESS_SUPPORT_FRONTEND_OPENSHIFT_ROUTE=

# ---------------------------------------------------------------------------
# GLS CX Zones & Groups (JSON)
# ---------------------------------------------------------------------------
# For teams with per-group sub-teams (e.g. GLS CX APAC), set this JSON var.
# The frontend reads it at startup to seed zones/groups in state.json.
# The backend reads it to build per-group TeamConfig entries dynamically.
#
# Format:
#   SNOW_GROUPS_CONFIG={"zones":[{"id":"apac","name":"APAC"}],"groups":[{"id":"anz","name":"ANZ","zone_id":"apac","assignment_group_ids":["<sys_id>"]}]}
#
# When set, the "Zones & Groups" management tab in the frontend is hidden
# and the zone/group CRUD routes return 403.
SNOW_GROUPS_CONFIG=

# The frontend URL used by the autoassign backend to call /api/shift?group=<slug>
FRONTEND_OPENSHIFT_ROUTE=

# Jira API (for future use)
JIRA_SERVER_URL=
JIRA_API_USER=
JIRA_API_TOKEN=